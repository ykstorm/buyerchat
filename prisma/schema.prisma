generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id                  String         @id @default(cuid())
  projectName         String
  builderName         String
  microMarket         String
  minPrice            Float
  maxPrice            Float
  pricePerSqft        Float
  pricePerSqftType    String   @default("SBU")
  loadingFactor       Float    @default(1.37)
  charges             Json     @default("[]")
  allInPrice          Float?
  availableUnits      Int
  possessionDate      DateTime
  reraNumber          String         @unique
  amenities           String[]
  latitude            Float
  longitude           Float
  constructionStatus  String
  priceNote           String?
  unitTypes           String[]
  isActive            Boolean        @default(true)
  locationScore       Float          @default(50)
  amenitiesScore      Float          @default(50)
  sopPlanning         Float          @default(0)
  sopGrowth           Float          @default(0)
  sopTotal            Float          @default(0)
  infrastructureScore Float          @default(50)
  demandScore         Float          @default(50)
  builderGradeScore   Float          @default(50)
  decisionTag         String?
  honestConcern       String?
  analystNote         String?
  // Source tracking for buyer-facing free-text fields. Required after Agent 10
  // surfaced fabricated stats in Project.analystNote (e.g. Vishwanath Sarathya
  // had unverified "ET Industry Leader 2023" / "34 years Gujarat experience"
  // claims). Source vocabulary: 'operator' | 'ai_generated' | 'imported' |
  // 'unknown'. Writes flow through src/lib/project-content-source.ts which
  // BLOCKS source='ai_generated' from reaching these fields and Sentry-warns
  // on the attempt. The admin edit page renders source badges so unverified
  // ('unknown', 'imported') content is visually flagged for operator review.
  analystNoteSource       String?
  analystNoteAuthor       String?
  analystNoteVerifiedAt   DateTime?
  honestConcernSource     String?
  honestConcernAuthor     String?
  honestConcernVerifiedAt DateTime?
  possessionFlag      String?
  configurations      String?
  bankApprovals       String?
  carpetSqftMin       Int?
  sbaSqftMin          Int?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  builder             Builder        @relation(fields: [builderName], references: [builderName], onDelete: Restrict)
  priceHistory        PriceHistory[]
  siteVisits          SiteVisit[]
  deals               Deal[]
  savedBy             SavedProject[]
  pricing             ProjectPricing?
  pricingHistory      PricingHistory[]

  @@index([microMarket])
  @@index([isActive])
  @@index([decisionTag])
  @@index([constructionStatus])
  @@index([builderName])
}

model Builder {
  id                  String    @id @default(cuid())
  builderName         String    @unique
  brandName           String
  deliveryScore       Float
  reraScore           Float
  qualityScore        Float
  financialScore      Float
  responsivenessScore Float
  totalTrustScore     Float
  grade               String
  partnerStatus       Boolean   @default(false)
  commissionRatePct   Float     @default(1.5)
  contactEmail        String?
  contactPhone        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  projects            Project[]
  agreementSigned   Boolean @default(false)
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime       @default(now())
  accounts      Account[]
  sessions      Session[]
  siteVisits    SiteVisit[]
  chatSessions  ChatSession[]
  savedProjects SavedProject[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PriceHistory {
  id           String   @id @default(cuid())
  projectId    String
  pricePerSqft Float
  recordedAt   DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Locality {
  id              String   @id @default(cuid())
  name            String   @unique
  yoyGrowthPct    Float
  demandScore     Float
  avgPricePerSqft Float
  updatedAt       DateTime @updatedAt
}

model Infrastructure {
  id             String   @id @default(cuid())
  name           String   @unique
  type           String
  priceImpactPct Float
  sourceUrl      String
  createdAt      DateTime @default(now())
}

model Amenity {
  id            String   @id @default(cuid())
  name          String
  type          String
  latitude      Float
  longitude     Float
  qualityRating Float
  createdAt     DateTime @default(now())

  @@unique([name, latitude, longitude])
}

model BuyerDemand {
  id           String   @id @default(cuid())
  weekOf       DateTime
  inquiryCount Int
  createdAt    DateTime @default(now())
}

model SiteVisit {
  id                 String   @id @default(cuid())
  visitToken         String   @unique
  userId             String
  projectId          String
  otpVerified        Boolean  @default(false)
  visitScheduledDate DateTime
  visitCompleted     Boolean  @default(false)
  createdAt          DateTime @default(now())
  expiresAt          DateTime?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  builderAcknowledged Boolean  @default(false)
  leadRegisteredAt    DateTime?
  buyerName           String?
  buyerPhone          String?
  buyerEmail          String?

  // Visit follow-up scheduler (Agent 8) — playbook PARTS B, D, F.
  // Each timestamp is set when the corresponding follow-up message is fired,
  // making computeFollowupsDue idempotent. postVisit72Closed is a boolean
  // because it has no time window — it is a one-shot graceful-exit flag.
  followupT24Sent     DateTime?
  followupT3Sent      DateTime?
  followupT1Sent      DateTime?
  postVisitT1Sent     DateTime?
  postVisitT24Sent    DateTime?
  postVisitT48Sent    DateTime?
  postVisit72Closed   Boolean   @default(false)

  @@index([userId])
  @@index([projectId])
  @@index([visitCompleted])
  @@index([expiresAt])
  @@index([visitScheduledDate])
}

// CRMEvent — append-only audit log for every CRM-side touchpoint
// (follow-ups, junk flags, bypass alerts). Consumed by /admin/buyers
// detail timeline and the founder dashboard alerting layer.
model CRMEvent {
  id          String   @id @default(cuid())
  sessionId   String?
  buyerId     String?
  visitId     String?
  kind        String   // 'followup_t24' | 'followup_t3' | 'followup_t1' | 'post_visit_t1' | 'post_visit_t24' | 'post_visit_t48' | 'post_visit_t72_close' | 'junk_marked' | 'junk_unmarked'
  payload     Json?
  channel     String   // 'whatsapp' | 'in_app' | 'email'
  createdAt   DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([buyerId, createdAt])
  @@index([visitId, createdAt])
}


model ChatSession {
  id                   String   @id @default(cuid())
  sessionId            String   @unique
  userId               String?
  userMessage          String
  aiResponse           String   @db.Text
  intent               String
  tokensUsed           Int      @default(0)
  projectsMentioned    String[]
  responsePassedChecks Boolean  @default(true)
  violations           String[]
  createdAt            DateTime @default(now())
  user                 User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  buyerStage        String   @default("intent_capture")
buyerPersona      String?
buyerBudget       Int?
buyerConfig       String?
buyerPurpose      String?
qualificationDone Boolean  @default(false)
projectsDisclosed String[]
lastMessageAt     DateTime @updatedAt
customName        String?
systemPromptVersion String @default("v3")
// Stage A soft capture (Agent 4) — only /api/chat/capture writes here.
// captureStage: 'soft' | 'verified' | 'skipped' | NULL (not yet asked).
capturedPhone     String?
capturedName      String?
captureStage      String?
capturedAt        DateTime?
messages          ChatMessageLog[]
deals             Deal[]

  @@index([userId])
  @@index([buyerStage])
  @@index([lastMessageAt])
  @@index([createdAt])
  @@index([captureStage])
}

model SavedProject {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
}
model ChatMessageLog {
  id          String      @id @default(cuid())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String
  content     String      @db.Text
  tokensUsed  Int?
  responseMs  Int?
  violations  String[]
  createdAt   DateTime    @default(now())

  @@index([sessionId])
}
model Deal {
  id               String    @id @default(cuid())
  dealNumber       String    @unique
  sessionId        String?
  session          ChatSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  projectId        String?
  project          Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  builderBrandName String
  buyerName        String
  dealValue        Float
  commissionRate   Float     @default(1.5)
  commissionAmount Float
  invoiceDate      DateTime  @default(now())
  paymentStatus    String    @default("pending")
  paymentDate      DateTime?
  createdAt        DateTime  @default(now())

  @@index([createdAt])
  @@index([projectId])
  @@index([sessionId])
  @@index([paymentStatus])
}
model MarketAlert {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String
  projectName String?
  createdAt   DateTime @default(now())
  isRead      Boolean  @default(false)
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entity     String
  entityId   String?
  data       Json?
  userEmail  String
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([entity])
  @@index([userEmail])
  @@index([createdAt])
}

model Embedding {
  id         String   @id @default(cuid())
  sourceType String
  sourceId   String
  content    String   @db.Text
  embedding  Unsupported("vector(1536)")
  tokens     Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([sourceType, sourceId])
  @@index([sourceType, sourceId])
}

// Operator-curated amenity inventory for Bopal/Shela/South Bopal.
// Source of truth for PART 11 GUARD_LIST — retriever grounds amenity
// responses to rows in this table to block hallucinations like
// "Auda Garden" / "CIMS Hospital" / "Bopal Lake Park" that surfaced
// in Sentry (JS-NEXTJS-K) when the model free-associated around a
// category keyword. Populated via scripts/seed-location-data.mjs.
//
// category values (canonical, enforced by seed + context-builder):
//   'park' | 'hospital' | 'atm' | 'bank' | 'school' | 'mall' |
//   'club'  | 'temple'   | 'transport'
//
// microMarket mirrors Project.microMarket ('Bopal' | 'SBopal' | 'Shela').
model LocationData {
  id          String   @id @default(cuid())
  category    String
  name        String
  microMarket String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, name, microMarket])
  @@index([category])
  @@index([microMarket])
  @@index([category, microMarket])
}

model ProjectPricing {
  id                String   @id @default(cuid())
  projectId         String   @unique
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  propertyType      String   // "flat" | "villa"

  // FLAT fields (nullable — only used when propertyType=="flat")
  basicRatePerSqft  Int?
  plcRatePerSqft    Int?
  floorRisePerSqft  Int?
  floorRiseFrom     Int?     @default(1)
  unitFloorNo       Int?

  // VILLA fields (nullable — only used when propertyType=="villa")
  landRatePerSqyd   Int?
  consRatePerSqyd   Int?
  plcRatePerSqyd    Int?

  // Dev & Govt
  audaGebAecCharge  Int?
  developmentFixed  Int?
  infrastructure    Int?

  // Maintenance & Deposits
  societyMaintDeposit   Int?
  advanceRunningMaint   Int?
  townshipDeposit       Int?
  townshipAdvance       Int?

  // Fixed Charges
  carParkingAmount  Int?
  carParkingCount   Int?     @default(1)
  clubMembership    Int?
  legalCharges      Int?
  otherCharges      Json?    // [{ label: string, amount: number }]

  // Tax & Stamp
  saleDeedAmount      Int?
  gstPercent          Float  @default(5.0)
  stampDutyPercent    Float  @default(4.9)
  registrationPercent Float  @default(1.0)

  // Computed (denormalized for fast query)
  basicCostTotal    Int?
  plcTotal          Int?
  devGovtTotal      Int?
  maintenanceTotal  Int?
  fixedChargesTotal Int?
  stampRegTotal     Int?
  gstTotal          Int?
  grandTotalAllIn   Int?

  // Per-BHK configuration table (Bug B) — drives per-flat all-in totals.
  // Shape: [
  //   { type: "2BHK", sbaSqft: number, carpetSqft: number, allInTotal: number },
  //   { type: "3BHK", sbaSqft: 1450, carpetSqft: 950, allInTotal: number },
  //   ...
  // ]
  bhkConfigs        Json?

  // Metadata
  lastUpdated       DateTime @updatedAt
  updatedBy         String?
  pricingVersion    Int      @default(1)

  history           PricingHistory[]

  @@index([projectId])
}

model PricingHistory {
  id                String   @id @default(cuid())
  pricingId         String
  pricing           ProjectPricing @relation(fields: [pricingId], references: [id], onDelete: Cascade)
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  basicRatePerSqft  Int?
  grandTotalAllIn   Int?
  snapshotJson      Json     // full pricing snapshot at this point
  changedAt         DateTime @default(now())
  changedBy         String?
  changeReason      String?

  @@index([projectId, changedAt])
}