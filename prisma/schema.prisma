generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
}

model Project {
  id                String   @id @default(cuid())
  projectName       String
  builderName       String
  microMarket       String
  minPrice          Float
  maxPrice          Float
  pricePerSqft      Float
  availableUnits    Int
  possessionDate    DateTime
  reraNumber        String   @unique
  amenities         String[]
  latitude          Float
  longitude         Float
  constructionStatus String
  unitTypes         String[]
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  builder           Builder  @relation(fields: [builderName], references: [builderName])
  priceHistory      PriceHistory[]
  siteVisits        SiteVisit[]
  deals             Deal[]
}

model Builder {
  id                    String    @id @default(cuid())
  builderName           String    @unique
  brandName             String
  deliveryScore         Float     // out of 20
  reraScore             Float     // out of 20
  qualityScore          Float     // out of 20
  financialScore        Float     // out of 15
  responsivenessScore   Float     // out of 15
  totalTrustScore       Float     // out of 100
  grade                 String    // A-F
  partnerStatus         Boolean   @default(false)
  commissionRatePct     Float     @default(1.5)
  contactEmail          String
  contactPhone          String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  projects              Project[]
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime   @default(now())
  accounts      Account[]
  sessions      Session[]
  siteVisits    SiteVisit[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PriceHistory {
  id           String   @id @default(cuid())
  projectId    String
  pricePerSqft Float
  recordedAt   DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id])
}

model Locality {
  id            String   @id @default(cuid())
  name          String   @unique
  yoyGrowthPct  Float
  demandScore   Float
  avgPricePerSqft Float
  updatedAt     DateTime @updatedAt
}

model Infrastructure {
  id             String   @id @default(cuid())
  name           String
  type           String
  priceImpactPct Float
  sourceUrl      String
  createdAt      DateTime @default(now())
}

model Amenity {
  id            String   @id @default(cuid())
  name          String
  type          String
  latitude      Float
  longitude     Float
  qualityRating Float
  createdAt     DateTime @default(now())
}

model BuyerDemand {
  id           String   @id @default(cuid())
  weekOf       DateTime
  inquiryCount Int
  createdAt    DateTime @default(now())
}

model SiteVisit {
  id                  String    @id @default(cuid())
  visitToken          String    @unique
  userId              String
  projectId           String
  otpVerified         Boolean   @default(false)
  visitScheduledDate  DateTime
  visitCompleted      Boolean   @default(false)
  createdAt           DateTime  @default(now())
  user                User      @relation(fields: [userId], references: [id])
  project             Project   @relation(fields: [projectId], references: [id])
}

model Deal {
  id                String   @id @default(cuid())
  projectId         String
  commissionAmt     Float
  attributionToken  String
  closedAt          DateTime
  createdAt         DateTime @default(now())
  project           Project  @relation(fields: [projectId], references: [id])
}