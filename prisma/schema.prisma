generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id                  String         @id @default(cuid())
  projectName         String
  builderName         String
  microMarket         String
  minPrice            Float
  maxPrice            Float
  pricePerSqft        Float
  pricePerSqftType    String   @default("SBU")
  loadingFactor       Float    @default(1.37)
  charges             Json     @default("[]")
  allInPrice          Float?
  availableUnits      Int
  possessionDate      DateTime
  reraNumber          String         @unique
  amenities           String[]
  latitude            Float
  longitude           Float
  constructionStatus  String
  priceNote           String?
  unitTypes           String[]
  isActive            Boolean        @default(true)
  locationScore       Float          @default(50)
  amenitiesScore      Float          @default(50)
  sopPlanning         Float          @default(0)
  sopGrowth           Float          @default(0)
  sopTotal            Float          @default(0)
  infrastructureScore Float          @default(50)
  demandScore         Float          @default(50)
  builderGradeScore   Float          @default(50)
  decisionTag         String?
  honestConcern       String?
  analystNote         String?
  possessionFlag      String?
  configurations      String?
  bankApprovals       String?
  carpetSqftMin       Int?
  sbaSqftMin          Int?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  builder             Builder        @relation(fields: [builderName], references: [builderName], onDelete: Restrict)
  priceHistory        PriceHistory[]
  siteVisits          SiteVisit[]
  deals               Deal[]
  savedBy             SavedProject[]
  pricing             ProjectPricing?
  pricingHistory      PricingHistory[]

  @@index([microMarket])
  @@index([isActive])
  @@index([decisionTag])
  @@index([constructionStatus])
  @@index([builderName])
}

model Builder {
  id                  String    @id @default(cuid())
  builderName         String    @unique
  brandName           String
  deliveryScore       Float
  reraScore           Float
  qualityScore        Float
  financialScore      Float
  responsivenessScore Float
  totalTrustScore     Float
  grade               String
  partnerStatus       Boolean   @default(false)
  commissionRatePct   Float     @default(1.5)
  contactEmail        String?
  contactPhone        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  projects            Project[]
  agreementSigned   Boolean @default(false)
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime       @default(now())
  accounts      Account[]
  sessions      Session[]
  siteVisits    SiteVisit[]
  chatSessions  ChatSession[]
  savedProjects SavedProject[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PriceHistory {
  id           String   @id @default(cuid())
  projectId    String
  pricePerSqft Float
  recordedAt   DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Locality {
  id              String   @id @default(cuid())
  name            String   @unique
  yoyGrowthPct    Float
  demandScore     Float
  avgPricePerSqft Float
  updatedAt       DateTime @updatedAt
}

model Infrastructure {
  id             String   @id @default(cuid())
  name           String   @unique
  type           String
  priceImpactPct Float
  sourceUrl      String
  createdAt      DateTime @default(now())
}

model Amenity {
  id            String   @id @default(cuid())
  name          String
  type          String
  latitude      Float
  longitude     Float
  qualityRating Float
  createdAt     DateTime @default(now())

  @@unique([name, latitude, longitude])
}

model BuyerDemand {
  id           String   @id @default(cuid())
  weekOf       DateTime
  inquiryCount Int
  createdAt    DateTime @default(now())
}

model SiteVisit {
  id                 String   @id @default(cuid())
  visitToken         String   @unique
  userId             String
  projectId          String
  otpVerified        Boolean  @default(false)
  visitScheduledDate DateTime
  visitCompleted     Boolean  @default(false)
  createdAt          DateTime @default(now())
  expiresAt          DateTime?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  builderAcknowledged Boolean  @default(false)
  leadRegisteredAt    DateTime?
  buyerName           String?
  buyerPhone          String?
  buyerEmail          String?

  @@index([userId])
  @@index([projectId])
  @@index([visitCompleted])
  @@index([expiresAt])
}


model ChatSession {
  id                   String   @id @default(cuid())
  sessionId            String   @unique
  userId               String?
  userMessage          String
  aiResponse           String   @db.Text
  intent               String
  tokensUsed           Int      @default(0)
  projectsMentioned    String[]
  responsePassedChecks Boolean  @default(true)
  violations           String[]
  createdAt            DateTime @default(now())
  user                 User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  buyerStage        String   @default("intent_capture")
buyerPersona      String?
buyerBudget       Int?
buyerConfig       String?
buyerPurpose      String?
qualificationDone Boolean  @default(false)
projectsDisclosed String[]
lastMessageAt     DateTime @updatedAt
customName        String?
messages          ChatMessageLog[]
deals             Deal[]

  @@index([userId])
  @@index([buyerStage])
  @@index([lastMessageAt])
  @@index([createdAt])
}

model SavedProject {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
}
model ChatMessageLog {
  id          String      @id @default(cuid())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String
  content     String      @db.Text
  tokensUsed  Int?
  responseMs  Int?
  violations  String[]
  createdAt   DateTime    @default(now())

  @@index([sessionId])
}
model Deal {
  id               String    @id @default(cuid())
  dealNumber       String    @unique
  sessionId        String?
  session          ChatSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  projectId        String?
  project          Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  builderBrandName String
  buyerName        String
  dealValue        Float
  commissionRate   Float     @default(1.5)
  commissionAmount Float
  invoiceDate      DateTime  @default(now())
  paymentStatus    String    @default("pending")
  paymentDate      DateTime?
  createdAt        DateTime  @default(now())

  @@index([createdAt])
  @@index([projectId])
  @@index([sessionId])
  @@index([paymentStatus])
}
model MarketAlert {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String
  projectName String?
  createdAt   DateTime @default(now())
  isRead      Boolean  @default(false)
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entity     String
  entityId   String?
  data       Json?
  userEmail  String
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([entity])
  @@index([userEmail])
  @@index([createdAt])
}

model Embedding {
  id         String   @id @default(cuid())
  sourceType String
  sourceId   String
  content    String   @db.Text
  embedding  Unsupported("vector(1536)")
  tokens     Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([sourceType, sourceId])
  @@index([sourceType, sourceId])
}

model ProjectPricing {
  id                String   @id @default(cuid())
  projectId         String   @unique
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  propertyType      String   // "flat" | "villa"

  // FLAT fields (nullable — only used when propertyType=="flat")
  basicRatePerSqft  Int?
  plcRatePerSqft    Int?
  floorRisePerSqft  Int?
  floorRiseFrom     Int?     @default(1)
  unitFloorNo       Int?

  // VILLA fields (nullable — only used when propertyType=="villa")
  landRatePerSqyd   Int?
  consRatePerSqyd   Int?
  plcRatePerSqyd    Int?

  // Dev & Govt
  audaGebAecCharge  Int?
  developmentFixed  Int?
  infrastructure    Int?

  // Maintenance & Deposits
  societyMaintDeposit   Int?
  advanceRunningMaint   Int?
  townshipDeposit       Int?
  townshipAdvance       Int?

  // Fixed Charges
  carParkingAmount  Int?
  carParkingCount   Int?     @default(1)
  clubMembership    Int?
  legalCharges      Int?
  otherCharges      Json?    // [{ label: string, amount: number }]

  // Tax & Stamp
  saleDeedAmount      Int?
  gstPercent          Float  @default(5.0)
  stampDutyPercent    Float  @default(4.9)
  registrationPercent Float  @default(1.0)

  // Computed (denormalized for fast query)
  basicCostTotal    Int?
  plcTotal          Int?
  devGovtTotal      Int?
  maintenanceTotal  Int?
  fixedChargesTotal Int?
  stampRegTotal     Int?
  gstTotal          Int?
  grandTotalAllIn   Int?

  // Metadata
  lastUpdated       DateTime @updatedAt
  updatedBy         String?
  pricingVersion    Int      @default(1)

  history           PricingHistory[]

  @@index([projectId])
}

model PricingHistory {
  id                String   @id @default(cuid())
  pricingId         String
  pricing           ProjectPricing @relation(fields: [pricingId], references: [id], onDelete: Cascade)
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  basicRatePerSqft  Int?
  grandTotalAllIn   Int?
  snapshotJson      Json     // full pricing snapshot at this point
  changedAt         DateTime @default(now())
  changedBy         String?
  changeReason      String?

  @@index([projectId, changedAt])
}