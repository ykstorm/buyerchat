generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id                  String         @id @default(cuid())
  projectName         String
  builderName         String
  microMarket         String
  minPrice            Float
  maxPrice            Float
  pricePerSqft        Float
  availableUnits      Int
  possessionDate      DateTime
  reraNumber          String         @unique
  amenities           String[]
  latitude            Float
  longitude           Float
  constructionStatus  String
  priceNote           String?
  unitTypes           String[]
  isActive            Boolean        @default(true)
  locationScore       Float          @default(50)
  amenitiesScore      Float          @default(50)
  infrastructureScore Float          @default(50)
  demandScore         Float          @default(50)
  builderGradeScore   Float          @default(50)
  decisionTag         String?
  honestConcern       String?
  analystNote         String?
  possessionFlag      String?
  configurations      String?
  bankApprovals       String?
  carpetSqftMin       Int?
  sbaSqftMin          Int?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  builder             Builder        @relation(fields: [builderName], references: [builderName])
  priceHistory        PriceHistory[]
  siteVisits          SiteVisit[]
  deals               Deal[]
  savedBy             SavedProject[]
  
}

model Builder {
  id                  String    @id @default(cuid())
  builderName         String    @unique
  brandName           String
  deliveryScore       Float
  reraScore           Float
  qualityScore        Float
  financialScore      Float
  responsivenessScore Float
  totalTrustScore     Float
  grade               String
  partnerStatus       Boolean   @default(false)
  commissionRatePct   Float     @default(1.5)
  contactEmail        String?
  contactPhone        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  projects            Project[]
  agreementSigned   Boolean @default(false)
commissionRate    Float   @default(1.5)
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime       @default(now())
  accounts      Account[]
  sessions      Session[]
  siteVisits    SiteVisit[]
  chatSessions  ChatSession[]
  savedProjects SavedProject[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PriceHistory {
  id           String   @id @default(cuid())
  projectId    String
  pricePerSqft Float
  recordedAt   DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id])
}

model Locality {
  id              String   @id @default(cuid())
  name            String   @unique
  yoyGrowthPct    Float
  demandScore     Float
  avgPricePerSqft Float
  updatedAt       DateTime @updatedAt
}

model Infrastructure {
  id             String   @id @default(cuid())
  name           String   @unique
  type           String
  priceImpactPct Float
  sourceUrl      String
  createdAt      DateTime @default(now())
}

model Amenity {
  id            String   @id @default(cuid())
  name          String
  type          String
  latitude      Float
  longitude     Float
  qualityRating Float
  createdAt     DateTime @default(now())
}

model BuyerDemand {
  id           String   @id @default(cuid())
  weekOf       DateTime
  inquiryCount Int
  createdAt    DateTime @default(now())
}

model SiteVisit {
  id                 String   @id @default(cuid())
  visitToken         String   @unique
  userId             String
  projectId          String
  otpVerified        Boolean  @default(false)
  visitScheduledDate DateTime
  visitCompleted     Boolean  @default(false)
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            Project  @relation(fields: [projectId], references: [id])
  builderAcknowledged Boolean  @default(false)
  leadRegisteredAt    DateTime?
  buyerName           String?
  buyerPhone          String?
  buyerEmail          String?
}


model ChatSession {
  id                   String   @id @default(cuid())
  sessionId            String   @unique
  userId               String?
  userMessage          String
  aiResponse           String   @db.Text
  intent               String
  tokensUsed           Int      @default(0)
  projectsMentioned    String[]
  responsePassedChecks Boolean  @default(true)
  violations           String[]
  createdAt            DateTime @default(now())
  user                 User?    @relation(fields: [userId], references: [id])
  buyerStage        String   @default("intent_capture")
buyerPersona      String?
buyerBudget       Int?
buyerConfig       String?
buyerPurpose      String?
qualificationDone Boolean  @default(false)
projectsDisclosed String[]
lastMessageAt     DateTime @updatedAt
customName        String?
messages          ChatMessageLog[]
}

model SavedProject {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
}
model ChatMessageLog {
  id          String      @id @default(cuid())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String
  content     String      @db.Text
  tokensUsed  Int?
  responseMs  Int?
  violations  String[]
  createdAt   DateTime    @default(now())
}
model Deal {
  id               String    @id @default(cuid())
  dealNumber       String    @unique
  sessionId        String?
  projectId        String?
  project          Project?  @relation(fields: [projectId], references: [id])
  builderBrandName String
  buyerName        String
  dealValue        Float
  commissionRate   Float     @default(1.5)
  commissionAmount Float
  invoiceDate      DateTime  @default(now())
  paymentStatus    String    @default("pending")
  paymentDate      DateTime?
  createdAt        DateTime  @default(now())
}
model MarketAlert {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String
  projectName String?
  createdAt   DateTime @default(now())
  isRead      Boolean  @default(false)
}